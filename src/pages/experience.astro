---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience | Nestor Rodriguez" description="Professional experience of Nestor Rodriguez, an IT Support professional.">
    <!-- HERO -->
    <section class="hero" id="home" style="min-height: 50vh;">
        <div class="grid-3d">
            <div class="grid-plane"></div>
        </div>
        <div class="orb orb1"></div>
        <div class="hero-content">
            <div class="hero-tag">// My Journey</div>
            <h1 class="hero-name" style="font-size: clamp(3rem, 8vw, 6rem);"><span>Experience</span></h1>
            <p class="hero-desc">An overview of my professional IT support background.</p>
        </div>
    </section>

    <div class="divider"></div>

    <!-- EXPERIENCE -->
    <section id="experience" style="padding-top: 60px;">
        <div class="projects-grid reveal">
            <div class="project-card">
                <div class="project-thumb">
                    <div class="thumb-bg" style="background: linear-gradient(135deg, #0d1117, #0a2a2a);"></div>
                    <a href="https://hlpos.com/" target="_blank" rel="noopener noreferrer" style="z-index: 1; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 40px;">
                        <img src="https://hlpos.com/wp-content/uploads/2021/08/h-and-l-logo-white.svg" alt="H&L" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                    </a>
                </div>
                <div class="project-body">
                    <div class="project-tag">Jul 2025 – Mar 2026</div>
                    <div class="project-name">Customer Support Representative Lv1</div>
                    <div class="project-desc">Spearheaded front-line technical support for a diverse user base, ensuring rapid issue resolution. Engineered solutions for complex POS issues, mitigating downtime involving terminals, barcode scanners, and proprietary software.</div>
                    <div class="project-tags">
                        <span class="tag">H&L Adelaide</span><span class="tag">POS</span><span class="tag">Ticketing</span>
                    </div>
                </div>
            </div>
            <div class="project-card">
                <div class="project-thumb">
                    <div class="thumb-bg" style="background: #ffffff;"></div>
                    <a href="https://rayogas.com/" target="_blank" rel="noopener noreferrer" style="z-index: 1; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 40px;">
                        <img src="https://rayogas.com/images/web/common/img_logo_azul_header.png" alt="RayoGas SA" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                    </a>
                </div>
                <div class="project-body">
                    <div class="project-tag">May 2017 – Jan 2019</div>
                    <div class="project-name">IT Support Technician</div>
                    <div class="project-desc">Administered comprehensive hardware and software support to a 150+ user network. Architected and executed the mass deployment, configuration, and upgrade of over 150 Windows workstations.</div>
                    <div class="project-tags">
                        <span class="tag">RayoGas SA</span><span class="tag">Windows Deploy</span><span class="tag">O365</span>
                    </div>
                </div>
            </div>
            <div class="project-card">
                <div class="project-thumb">
                    <div class="thumb-bg" style="background: linear-gradient(135deg, #0d1117, #1a1a0a);"></div>
                    <a href="https://atento.com/es/atentonomundo/colombia" target="_blank" rel="noopener noreferrer" style="z-index: 1; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 40px;">
                        <img src="https://atento.com/wp-content/uploads/2024/04/atento-logo-blanco.svg" alt="Atento Colombia" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                    </a>
                </div>
                <div class="project-body">
                    <div class="project-tag">Jan 2015 – May 2017</div>
                    <div class="project-name">Customer Services Representative</div>
                    <div class="project-desc">Delivered elite telecommunications support for Claro Colombia, resolving network connectivity issues with high customer satisfaction. Handled 80+ complex technical requests daily.</div>
                    <div class="project-tags">
                        <span class="tag">Atento Colombia</span><span class="tag">Telecom</span><span class="tag">Networking</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT LINK -->
    <section id="contact" style="padding: 60px 0; text-align: center;">
        <div class="contact-inner reveal">
            <a href="/#contact" class="btn-primary" style="display: inline-block;">Get in Touch</a>
        </div>
    </section>
</Layout>
