---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Education - Nestor Rodriguez" description="Educational background and certifications of Nestor Rodriguez, an IT Support professional.">
    <!-- HERO -->
    <section class="hero" id="home" style="min-height: 50vh;">
        <div class="grid-3d">
            <div class="grid-plane"></div>
        </div>
        <div class="orb orb1"></div>
        <div class="hero-content">
            <div class="hero-tag">// Academic Background</div>
            <h1 class="hero-name" style="font-size: clamp(3rem, 8vw, 6rem);"><span>Education</span><br> & Certs</h1>
            <p class="hero-desc">Degrees and certifications verifying my IT expertise.</p>
        </div>
    </section>

    <div class="divider"></div>

    <!-- EDUCATION -->
    <section id="education" style="padding-top: 60px; padding-bottom: 20px;">
        <div class="section-label">// 01 — Education</div>
        <div class="section-title">Academic <em>Degrees</em></div>
        <div class="projects-grid reveal">
            <div class="project-card" style="transform-style: flat;">
                <div class="project-body hover-reveal-video">
                    <div class="project-tag">May 2020 – May 2022</div>
                    <div class="project-name">Diploma of IT</div>
                    <div class="project-desc">Nortwest College, Sydney. Key learning areas included web development and wireframing tools.</div>
                    <div class="video-reveal">
                        <a href="https://nortwest.edu.au/" target="_blank" rel="noopener noreferrer">
                            <img src="https://nortwest.edu.au/assets/img/Nortwest-Logo__NW-logo_sydney-campus.png" alt="Nortwest College" style="width: 100%; height: 180px; object-fit: contain; background: white; border-radius: 4px; padding: 15px; cursor: pointer;">
                        </a>
                    </div>
                </div>
            </div>
            <div class="project-card" style="transform-style: flat;">
                <div class="project-body hover-reveal-video">
                    <div class="project-tag">Jul 2012 – Apr 2018</div>
                    <div class="project-name">Bachelor of Systems Engineering</div>
                    <div class="project-desc">UNAD, Colombia. Key learning areas included networking, helpdesk, system analysis, and software development.</div>
                    <div class="video-reveal">
                        <a href="https://www.unad.edu.co/" target="_blank" rel="noopener noreferrer">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/e/e1/Logo_unad_color.png" alt="UNAD" style="width: 100%; height: 180px; object-fit: contain; background: white; border-radius: 4px; padding: 15px; cursor: pointer;">
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="divider"></div>

    <!-- CERTIFICATIONS -->
    <section id="certifications" style="padding-top: 60px;">
        <div class="section-label">// 02 — Certifications</div>
        <div class="section-title">Professional <em>Certificates</em></div>
        
        <div class="cert-showcase reveal">
            <div class="cert-carousel-viewport">
                <div class="cert-carousel-track" id="certTrack">
                    <div class="cert-slide" style="flex: 1;">
                        <img src="https://www.e-tp.uk/wp-content/uploads/2019/01/ITIL-f-v3.jpg" alt="ITIL V3 Foundation">
                    </div>
                    <div class="cert-slide" style="flex: 1;">
                        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRWfA3kISZfolzgLeoJl7whdJ1D4ohoMQAtOA&s" alt="Google IT Support">
                    </div>
                    <div class="cert-slide" style="flex: 1;">
                        <img src="https://www.certifiedskills.academy/wp-content/uploads/2019/07/mcsa-bi-reporting.png" alt="Microsoft Certified Professional">
                    </div>
                    <div class="cert-slide" style="flex: 1;">
                        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQq_3RU5actbIo68dOqTXt_2qC1XZskmz7DGA&s" alt="CompTIA A+">
                    </div>
                </div>
            </div>
            
            <div class="cert-list-wrapper">
                <button class="cert-nav-btn cert-up" aria-label="Previous">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
                </button>
                <div class="cert-list">
                    <div class="cert-list-item active" data-index="0">
                        <div class="cert-tag">Certification</div>
                        <div class="cert-name">ITIL V3 Foundation</div>
                        <div class="cert-desc">Certified in aligning IT services with business needs, framework mastery, and proactive support lifecycle management.</div>
                    </div>
                    <div class="cert-list-item" data-index="1">
                        <div class="cert-tag">Certification</div>
                        <div class="cert-name">Google IT Support</div>
                        <div class="cert-desc">Comprehensive certification covering troubleshooting, customer service, networking, OS, and systems security.</div>
                    </div>
                    <div class="cert-list-item" data-index="2">
                        <div class="cert-tag">Certification</div>
                        <div class="cert-name">Microsoft Certified Professional</div>
                        <div class="cert-desc">Demonstrated foundational knowledge and technical expertise in Microsoft products and solutions.</div>
                    </div>
                    <div class="cert-list-item" data-index="3">
                        <div class="cert-tag">Certification</div>
                        <div class="cert-name">CompTIA A+</div>
                        <div class="cert-desc">Validated skills in hardware, software, and networking troubleshooting and end-point management.</div>
                    </div>
                </div>
                <button class="cert-nav-btn cert-down" aria-label="Next">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </button>
            </div>
        </div>
    </section>

    <!-- CONTACT LINK -->
    <section id="contact" style="padding: 60px 0; text-align: center;">
        <div class="contact-inner reveal">
            <a href={`${import.meta.env.BASE_URL}#contact`} class="btn-primary" style="display: inline-block;">Get in Touch</a>
        </div>
    </section>
</Layout>

<script is:inline>
    // Certifications Carousel Logic
    const certItems = document.querySelectorAll('.cert-list-item');
    const certTrack = document.getElementById('certTrack');
    const btnUp = document.querySelector('.cert-up');
    const btnDown = document.querySelector('.cert-down');
    
    if (certItems.length > 0 && certTrack) {
        let startIndex = 0;
        const visibleCount = 2;
        const totalItems = certItems.length;

        certTrack.style.width = (totalItems * 100) + '%';

        const renderList = () => {
            certItems.forEach((item, i) => {
                if (i >= startIndex && i < startIndex + visibleCount) {
                    item.style.display = 'block';
                    setTimeout(() => item.style.opacity = '1', 50);
                } else {
                    item.style.display = 'none';
                    item.style.opacity = '0';
                }
            });
            
            if (btnUp) {
                btnUp.style.opacity = startIndex === 0 ? '0.3' : '1';
                btnUp.style.cursor = startIndex === 0 ? 'default' : 'pointer';
            }
            if (btnDown) {
                btnDown.style.opacity = startIndex >= totalItems - visibleCount ? '0.3' : '1';
                btnDown.style.cursor = startIndex >= totalItems - visibleCount ? 'default' : 'pointer';
            }
        };

        if (btnUp) {
            btnUp.addEventListener('click', () => {
                if (startIndex > 0) {
                    startIndex--;
                    renderList();
                }
            });
        }

        if (btnDown) {
            btnDown.addEventListener('click', () => {
                if (startIndex < totalItems - visibleCount) {
                    startIndex++;
                    renderList();
                }
            });
        }

        const listWrapper = document.querySelector('.cert-list-wrapper');
        if (listWrapper) {
            let isWheelScrolling = false;
            listWrapper.addEventListener('wheel', (e) => {
                e.preventDefault();
                if (isWheelScrolling) return;

                if (e.deltaY > 0) { // scroll down
                    if (startIndex < totalItems - visibleCount) {
                        startIndex++;
                        renderList();
                        isWheelScrolling = true;
                        setTimeout(() => isWheelScrolling = false, 300);
                    }
                } else if (e.deltaY < 0) { // scroll up
                    if (startIndex > 0) {
                        startIndex--;
                        renderList();
                        isWheelScrolling = true;
                        setTimeout(() => isWheelScrolling = false, 300);
                    }
                }
            });
        }

        // Init visibility
        renderList();

        // Hover tracking
        certItems.forEach((item, index) => {
            item.addEventListener('mouseenter', () => {
                certItems.forEach(i => i.classList.remove('active'));
                item.classList.add('active');
                certTrack.style.transform = `translateX(-${(index * 100) / totalItems}%)`;
            });
        });
    }
</script>
