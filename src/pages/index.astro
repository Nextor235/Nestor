---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nestor Rodriguez | IT Support Specialist">
    <section class="hero" id="home">
        <div class="grid-3d">
            <div class="grid-plane"></div>
        </div>
        <div class="orb orb1"></div>
        <div class="orb orb2"></div>
        <div class="orb orb3"></div>

        <div class="hero-content">
            <div class="hero-tag">// Available for work</div>
            <h1 class="hero-name"><span>Nestor Rodriguez</span></h1>
            <p class="hero-role">IT Support <span>Specialist</span></p>
            <p class="hero-desc">Dedicated IT Support Specialist with 2+ years of full-cycle experience—from hardware deployment and network troubleshooting to end-user empowerment. Proven track record of minimizing downtime and elevating team productivity.</p>
            <div class="hero-btns">
                <a href="/experience" class="btn-primary">View Experience</a>
                <a href="#contact" class="btn-secondary">Get in Touch</a>
            </div>
        </div>
        <div class="scroll-hint">Scroll</div>
    </section>

    <div class="divider"></div>

    <section id="about">
        <div class="section-label">// 01 — About</div>
        <div class="section-title">Who is <em>Nestor?</em></div>
        <div class="about-grid reveal">
            <div class="about-text">
                <p>I'm <strong>Nestor Rodriguez</strong>, a results-oriented IT Professional with a diverse background in resolving complex technical challenges, protecting IT assets, and delivering exceptional remote and on-site support.</p>
                <p>Backed by a <strong>Bachelor of Systems Engineering</strong> and a <strong>Diploma of Information Technology</strong>, I blend deep technical acumen with strong interpersonal skills to drive measurable improvements in system reliability, security, and overall user satisfaction.</p>
                <p>Whether it's <strong>optimizing Windows Server environments</strong>, <strong>managing Active Directory</strong>, or streamlining IT workflows through proactive support, I bring patience, clarity, and precision to every interaction.</p>
            </div>
            <div class="tilt-card" id="aboutCard">
                <div class="card-shine"></div>
                <div class="stats-grid">
                    <div class="stat"><div class="stat-num" data-target="2" data-suffix="+">0+</div><div class="stat-label">Years Exp</div></div>
                    <div class="stat"><div class="stat-num" data-target="96" data-suffix="%">0%</div><div class="stat-label">Resolution</div></div>
                    <div class="stat"><div class="stat-num" data-target="150" data-suffix="+">0+</div><div class="stat-label">Users Supported</div></div>
                    <div class="stat"><div class="stat-num" data-target="24" data-suffix="h">0h</div><div class="stat-label">Response SLA</div></div>
                </div>
            </div>
        </div>
    </section>

    <div class="divider"></div>

    <section id="skills">
        <div class="section-label">// 02 — Skills</div>
        <div class="section-title">Core <em>Competencies</em></div>
        <div class="skills-container">
            <div class="skills-grid reveal">
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>
                    <div class="skill-name">Tech Support</div>
                    <div class="skill-desc">Remote & on-site technical support, hardware/software diagnosis, and Microsoft 365 troubleshooting.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:95%"></div></div>
                </div>
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3"/><path d="M12 12V8"/></svg></span>
                    <div class="skill-name">OS & Networking</div>
                    <div class="skill-desc">Windows Server, Active Directory, TCP/IP, VPN, and internet connectivity troubleshooting.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:85%"></div></div>
                </div>
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg></span>
                    <div class="skill-name">Infrastructure</div>
                    <div class="skill-desc">User account administration, hardware installation, upgrades, and IT asset/inventory management.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:90%"></div></div>
                </div>
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                    <div class="skill-name">IT Security</div>
                    <div class="skill-desc">Secure remote access, patch management, endpoint protection, and cybersecurity awareness.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:80%"></div></div>
                </div>
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
                    <div class="skill-name">System Support</div>
                    <div class="skill-desc">Business application support, system performance monitoring, and software troubleshooting.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:85%"></div></div>
                </div>
                <div class="skill-card">
                    <span class="skill-icon"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                    <div class="skill-name">User Enablement</div>
                    <div class="skill-desc">Microsoft Office Suite, Google Workspace, user onboarding, training, and documentation.</div>
                    <div class="skill-bar-wrap"><div class="skill-bar" style="--w:92%"></div></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact">
        <div class="contact-inner reveal">
            <div class="section-label" style="text-align:center">// 05 — Contact</div>
            <div class="section-title">Let's <em>Connect</em></div>
            <p>Ready to contribute dependable IT support to a growing team. Have a system that needs fixing? A project that needs an IT mind? Drop me an email.</p>
            <div class="contact-links">
                <a href="mailto:nestor235@hotmail.com" class="contact-link"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> Email</a>
                <a href="https://github.com/Nextor235" class="contact-link"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg> GitHub</a>
                <a href="https://www.linkedin.com/in/nestor-rodriguezr/" class="contact-link"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg> LinkedIn</a>
            </div>
        </div>
    </section>
</Layout>

<script is:inline>
    const card = document.getElementById('aboutCard');
    if (card) {
        card.addEventListener('mousemove', e => {
            const r = card.getBoundingClientRect();
            const x = (e.clientX - r.left) / r.width;
            const y = (e.clientY - r.top) / r.height;
            card.style.transform = `perspective(600px) rotateY(${(x - 0.5) * 15}deg) rotateX(${(0.5 - y) * 15}deg)`;
            card.style.setProperty('--mx', `${x * 100}%`);
            card.style.setProperty('--my', `${y * 100}%`);
        });
        card.addEventListener('mouseleave', () => {
            card.style.transform = 'perspective(600px) rotateY(0) rotateX(0)';
        });
    }
</script>
